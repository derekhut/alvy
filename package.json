{
  "name": "@derekhut/alvy",
  "version": "1.0.1",
  "description": "Terminal-based vocabulary tool — learn English word roots with Chinese translations",
  "type": "module",
  "bin": {
    "alvy": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
